generator client {
  provider = "prisma-client"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

model Meeting {
  id String @id @default(cuid())
  host String?
  policyLevel Int
  date DateTime
  organisation String?
  purpose String?
  department String?
  othersAttending String?
  source String?
  registrantAddInfo String? 
  portalSource Source
  externalRecordId Int
  tags  Tag[]
}


model Tag {
  id Int @id @default(autoincrement())
  name String
  meetings Meeting[]
}

enum Source { 
  UK_Government
  Scottish_Lobbying_Register
}